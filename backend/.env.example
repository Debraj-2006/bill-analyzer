PROJECT_NAME="WBSEDCL Bill Analyzer"
MONGODB_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<appname>"
DATABASE_NAME="bill_analyzer_db"
SECRET_KEY="your-super-secret-key-change-in-prod"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
OTP_EXPIRE_MINUTES=5

# Gmail SMTP — OTP delivery
# Use an App Password (NOT your regular password)
# Generate one at: https://myaccount.google.com/apppasswords
GMAIL_USER="your-gmail@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# Anthropic (Claude AI) — get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY="sk-ant-..."

# Set to your Vercel frontend URL once deployed (e.g. https://bill-analyzer.vercel.app)
FRONTEND_URL=""
